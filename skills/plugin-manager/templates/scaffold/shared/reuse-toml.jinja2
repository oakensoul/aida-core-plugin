version = 1
SPDX-PackageName = "{{ plugin_name }}"
SPDX-PackageSupplier = "{{ author_name }} <{{ author_email }}>"
{% if repository_url %}
SPDX-PackageDownloadLocation = "{{ repository_url }}"
{% endif %}
SPDX-PackageComment = "Copyright is held by '{{ copyright_holder }}'; the roster lives in the AUTHORS file at the repo root. This file licenses paths that cannot carry inline SPDX headers (no comment syntax)."

# JSON has no comment syntax, so it cannot carry an inline SPDX header.
[[annotations]]
path = ["**.json", "**/**.json"]
precedence = "aggregate"
SPDX-FileCopyrightText = "{{ year }} {{ copyright_holder }}"
SPDX-License-Identifier = "{{ license_id }}"

# Dotfiles and version-marker files without comment syntax.
[[annotations]]
path = [
    ".gitignore",
    "**/.gitignore",
    "**/.gitkeep",
    ".python-version",
    ".nvmrc",
    ".node-version",
]
precedence = "aggregate"
SPDX-FileCopyrightText = "{{ year }} {{ copyright_holder }}"
SPDX-License-Identifier = "{{ license_id }}"

{% if language == "typescript" %}
# Lockfile generated by npm — not hand-authored.
[[annotations]]
path = ["package-lock.json", "yarn.lock", "pnpm-lock.yaml"]
precedence = "aggregate"
SPDX-FileCopyrightText = "{{ year }} {{ copyright_holder }}"
SPDX-License-Identifier = "{{ license_id }}"
{% endif %}
{% if language == "python" %}
# Lockfile generated by pip-tools / poetry — not hand-authored.
[[annotations]]
path = ["requirements.lock", "poetry.lock", "Pipfile.lock"]
precedence = "aggregate"
SPDX-FileCopyrightText = "{{ year }} {{ copyright_holder }}"
SPDX-License-Identifier = "{{ license_id }}"
{% endif %}
